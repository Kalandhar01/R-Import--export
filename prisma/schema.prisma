generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Submission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  country   String?
  subject   String?
  services  String?
  message   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Work {
  id        String   @id @default(cuid())
  title     String
  country   String
  industry  String
  scope     String
  result    String
  image     String
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
